<?xml version="1.0" encoding="utf-8"?>
<!--
    VulnDroid — Deliberately Vulnerable Android App
    ================================================
    SECURITY FINDINGS IN THIS FILE:

    [M7] android:debuggable="true"
         RISK: Allows ADB debugging on production-like builds. Attacker can attach
         a debugger, inspect memory, bypass checks, extract data via adb backup.
         FIX: Never set debuggable=true in release builds. Let the build system handle it.

    [M8] android:allowBackup="true"
         RISK: Full app data backup via `adb backup com.weijia.vulndroid` — no root required.
         Extracts databases, SharedPreferences, files containing auth tokens and PII.
         FIX: Set android:allowBackup="false" or use android:fullBackupContent rules.

    [M8] Exported Activity without permission (VulnerableDeepLinkActivity)
         RISK: Any app on the device can launch this Activity and trigger sensitive flows.
         FIX: Set android:exported="false" or add android:permission with custom permission.

    [M8] Exported BroadcastReceiver (TokenRefreshReceiver)
         RISK: Malicious apps can send broadcasts to trigger token refresh or read tokens.
         FIX: Use LocalBroadcastManager for internal broadcasts, restrict with permissions.

    [M8] Exported ContentProvider (UserDataProvider) without permission
         RISK: Any app can query the content provider and read user data from the database.
         FIX: Set android:exported="false" or add readPermission/writePermission.

    [M6] Excessive permissions — READ_CALL_LOG, RECORD_AUDIO not needed for a notes app
         RISK: Privacy violation, unnecessary data collection, Play Store policy violation.
         FIX: Request only permissions required for core functionality.

    [M5] usesCleartextTraffic="true" in network_security_config
         RISK: App sends data over unencrypted HTTP — vulnerable to MITM on any network.
         FIX: Enforce HTTPS only, remove cleartext allowance.
-->

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.weijia.vulndroid">

    <!-- [M6] Excessive permissions — notes app has no business need for these -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />     <!-- UNNECESSARY -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />       <!-- UNNECESSARY -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <application
        android:name="com.weijia.vulndroid.VulnDroidApp"
        android:allowBackup="true"
        android:debuggable="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.Vulndroid">

        <!-- Main entry point — correctly NOT exported -->
        <activity
            android:name="com.weijia.vulndroid.ui.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name="com.weijia.vulndroid.ui.dashboard.DashboardActivity"
            android:exported="false" />

        <activity android:name="com.weijia.vulndroid.ui.storage.StorageActivity"
            android:exported="false" />

        <activity android:name="com.weijia.vulndroid.ui.network.NetworkActivity"
            android:exported="false" />

        <activity android:name="com.weijia.vulndroid.ui.crypto.CryptoActivity"
            android:exported="false" />

        <!--
            [M8] VULNERABILITY: Exported Activity with no permission check.
            Attack: `adb shell am start -n com.weijia.vulndroid.ui.VulnerableDeepLinkActivity`
            Or from a malicious app: startActivity(Intent("com.weijia.vulndroid.RESET_PASSWORD"))
            This bypasses the login screen entirely and goes straight to password reset.
        -->
        <activity
            android:name="com.weijia.vulndroid.VulnerableDeepLinkActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="com.weijia.vulndroid.RESET_PASSWORD" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!--
            [M8] VULNERABILITY: Exported BroadcastReceiver with no permission.
            Attack: `adb shell am broadcast -a com.weijia.vulndroid.TOKEN_REFRESH`
            Triggers token refresh logic and logs the new token to Logcat.
        -->
        <receiver
            android:name="com.weijia.vulndroid.vulnerabilities.TokenRefreshReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.weijia.vulndroid.TOKEN_REFRESH" />
            </intent-filter>
        </receiver>

        <!--
            [M8] VULNERABILITY: Exported ContentProvider with no read/write permission.
            Attack: `adb shell content query -uri content://com.weijia.vulndroid.provider/users`
            Returns all user records including email, username, and plaintext password hash.
        -->
        <!--
            [M8] VULNERABILITY: Exported ContentProvider with no read/write permission.
            Attack: `adb shell content query -uri content://com.weijia.vulndroid.provider/users`
            Returns all user records including email, username, and plaintext password hash.
        -->
        <provider
            android:name="com.weijia.vulndroid.data.local.UserDataProvider"
            android:authorities="com.weijia.vulndroid.provider"
            android:exported="true"
            android:readPermission=""
            android:writePermission="" />

        <!-- SQL Injection demo screen — not exported, only reachable from Dashboard -->
        <activity android:name="com.weijia.vulndroid.SqlInjectionActivity"
            android:exported="false" />

    </application>

</manifest>
